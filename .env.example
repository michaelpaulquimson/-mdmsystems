# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=mdmsystems
POSTGRES_USER=mdm
POSTGRES_PASSWORD=mdm_dev_password
POSTGRES_PORT=5432

# Used when running the backend locally (outside Docker).
# In Docker, docker-compose.yml injects this directly from the POSTGRES_* vars above.
DATABASE_URL=postgres://mdm:mdm_dev_password@localhost:5432/mdmsystems

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=4000

# JWT — must be ≥32 chars.  # rotate before production!
JWT_SECRET=dev_only_jwt_secret_replace_before_going_to_prod

# Comma-separated CORS origins allowed to call the API
CORS_ORIGINS=http://localhost:5173

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug

# Bcrypt cost factor (12 recommended for production, lower for faster tests)
BCRYPT_ROUNDS=12

# Optional: protect /metrics endpoint in production.  Leave empty to skip auth in dev.
METRICS_TOKEN=

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=5173

# The URL the browser uses to reach the backend (not the Docker-internal URL)
VITE_API_URL=http://localhost:4000

# ─── Test DB ──────────────────────────────────────────────────────────────────
DATABASE_URL_TEST=postgres://mdm_test:mdm_test_password@localhost:5433/mdmsystems_test

# ─── Seed user passwords (dev only — printed in README for reviewers) ──────────
# admin@mdm.local  / admin123
# viewer@mdm.local / password123
# editor@mdm.local / password123
